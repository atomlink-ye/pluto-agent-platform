{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": [],
    "strict": true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@pluto/v2-core": ["packages/pluto-v2-core/src/index.ts"],
      "@pluto/v2-core/*": ["packages/pluto-v2-core/src/*"],
      "@pluto/v2-runtime": ["packages/pluto-v2-runtime/src/index.ts"],
      "@pluto/v2-runtime/*": ["packages/pluto-v2-runtime/src/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "docker/**/*.ts"],
  "exclude": ["node_modules", "dist", ".pluto", ".worktrees"]
}
