# Pluto MVP-alpha environment variables (placeholders only — no real secrets).

# Pluto control plane (host process or Docker service).
PLUTO_DATA_DIR=.pluto

# Default model used by OpenCode runtime. Stays free unless Link confirms otherwise.
OPENCODE_MODEL=opencode/minimax-m2.5-free

# OpenCode runtime endpoint (host:port). Used by the live adapter inside Docker.
OPENCODE_BASE_URL=http://pluto-runtime:4096
OPENCODE_PORT=4096

# Provider alias used by the live PaseoOpenCodeAdapter when it asks paseo to spawn agents.
# This must match an installed paseo provider that targets the local OpenCode runtime.
# Free-tier OpenCode profile recommended; do not switch to paid unless explicitly authorized.
PASEO_PROVIDER=opencode/minimax-m2.5-free

# Optional: pin which paseo CLI binary to use. Leave empty to use the one on $PATH.
PASEO_BIN=

# Where the Team Lead writes its evolving artifact inside a container.
# Live smoke watches this path to assert the closed loop.
PLUTO_LIVE_ARTIFACT_PATH=/workspace/.tmp/live-quickstart/hello-pluto.sh
