{
  "id": "fake-run-fixture",
  "description": "Static fixture documenting the expected event types and payload shapes emitted by a FakeAdapter-backed TeamRunService run.",
  "eventTypesInOrder": [
    "run_started",
    "lead_started",
    "worker_requested",
    "worker_requested",
    "worker_requested",
    "worker_started",
    "worker_completed",
    "worker_started",
    "worker_completed",
    "worker_started",
    "worker_completed",
    "lead_message",
    "artifact_created",
    "run_completed"
  ],
  "eventShapes": {
    "run_started": {
      "payload": ["taskId", "teamId", "prompt"]
    },
    "lead_started": {
      "roleId": "lead",
      "sessionIdPrefix": "fake-lead-",
      "payload": ["systemPrompt"]
    },
    "worker_requested": {
      "roleId": "planner|generator|evaluator",
      "payload": ["targetRole", "instructions"]
    },
    "worker_started": {
      "roleId": "planner|generator|evaluator",
      "sessionIdPrefix": "fake-worker-",
      "payload": ["instructions"]
    },
    "worker_completed": {
      "roleId": "planner|generator|evaluator",
      "sessionIdPrefix": "fake-worker-",
      "payload": ["output"]
    },
    "lead_message": {
      "roleId": "lead",
      "payload": {
        "kind": "summary",
        "markdown": "string"
      }
    },
    "artifact_created": {
      "payload": ["path", "bytes"]
    },
    "run_completed": {
      "payload": ["workerCount", "roles"]
    }
  },
  "requiredRoles": ["lead", "planner", "generator", "evaluator"],
  "forbiddenArtifactFragments": [
    "Instructions from the Team Lead:",
    "Reply with your contribution only"
  ]
}
