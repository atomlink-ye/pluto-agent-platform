{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "model": "opencode/minimax-m2.5-free",
  "agent": {
    "build": {
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "allow",
        "todowrite": "allow",
        "todoread": "allow",
        "question": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "external_directory": {
          "/workspace/**": "allow",
          "/root/**": "allow",
          "/tmp/**": "allow"
        }
      }
    }
  }
}
