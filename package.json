{
  "name": "pluto-agent-platform",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Pluto MVP-alpha: minimal agent team control plane on top of Paseo + OpenCode.",
  "type": "module",
  "engines": {
    "node": ">=20.10",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "bootstrap": "tsx src/cli/bootstrap.ts",
    "bootstrap:reset-local": "tsx src/cli/bootstrap.ts reset-local",
    "bootstrap:resume": "tsx src/cli/bootstrap.ts resume",
    "bootstrap:status": "tsx src/cli/bootstrap.ts status",
    "bootstrap:workspace": "tsx src/cli/bootstrap.ts workspace",
    "catalog": "tsx src/cli/catalog.ts",
    "compliance": "tsx src/cli/compliance.ts",
    "docker:build": "docker compose -f docker/compose.yml build",
    "docker:down": "docker compose -f docker/compose.yml down -v",
    "docker:live": "tsx docker/live-smoke.ts",
    "docker:up": "docker compose -f docker/compose.yml up -d",
    "documents": "tsx src/cli/documents.ts",
    "eval:workflow": "tsx evals/runner.ts",
    "extensions": "tsx src/cli/extensions.ts",
    "governance": "tsx src/cli/governance.ts",
    "integrations": "tsx src/cli/integrations.ts",
    "observability": "tsx src/cli/observability.ts",
    "ops": "tsx src/cli/ops.ts",
    "portability": "tsx src/cli/portability.ts",
    "publish": "tsx src/cli/publish.ts",
    "release": "tsx src/cli/release.ts",
    "review": "tsx src/cli/review.ts",
    "runs": "tsx src/cli/runs.ts",
    "schedules": "tsx src/cli/schedules.ts",
    "smoke:docker": "docker compose -f docker/compose.yml up -d --build && OPENCODE_BASE_URL=${OPENCODE_BASE_URL:-http://localhost:4096} PLUTO_LIVE_ADAPTER=paseo-opencode tsx docker/live-smoke.ts",
    "smoke:fake": "PLUTO_LIVE_ADAPTER=fake tsx docker/live-smoke.ts",
    "smoke:local": "PLUTO_LIVE_ADAPTER=paseo-opencode tsx docker/live-smoke.ts",
    "smoke:live": "PLUTO_LIVE_ADAPTER=paseo-opencode tsx docker/live-smoke.ts",
    "spec:hygiene": "node scripts/spec-hygiene.mjs",
    "submit": "tsx src/cli/submit.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "node scripts/verify.mjs",
    "workflows": "tsx src/cli/workflows.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
