{
  "name": "pluto-agent-platform",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Pluto MVP-alpha: minimal agent team control plane on top of Paseo + OpenCode.",
  "type": "module",
  "engines": {
    "node": ">=20.10",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build:runtime-cli": "pnpm --filter @pluto/v2-core build && pnpm --filter @pluto/v2-runtime build",
    "build": "tsc -p tsconfig.build.json",
    "docker:build": "docker compose -f docker/compose.yml build",
    "docker:down": "docker compose -f docker/compose.yml down -v",
    "docker:up": "docker compose -f docker/compose.yml up -d",
    "pluto:run": "pnpm build:runtime-cli && tsx src/cli/run.ts",
    "pluto:runs": "tsx packages/pluto-v2-runtime/src/cli/runs.ts",
    "smoke:live": "pnpm build:runtime-cli && pnpm --filter @pluto/v2-runtime exec tsx scripts/smoke-live.ts",
    "spec:hygiene": "node scripts/spec-hygiene.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "5.6.3",
    "vitest": "^2.1.8"
  }
}
