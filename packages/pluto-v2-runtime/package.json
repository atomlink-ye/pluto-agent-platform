{
  "name": "@pluto/v2-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Deterministic fake runtime package for Pluto v2.",
  "bin": {
    "pluto-tool": "./dist/src/cli/pluto-tool.js"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "smoke:mcp-injection": "tsx scripts/smoke-mcp-injection.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "dependencies": {
    "@pluto/v2-core": "workspace:*",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
